{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://compactbench.dev/schemas/template-v1.json",
  "title": "CompactBench Template",
  "description": "Benchmark template definition. Version 1.0.0.",
  "type": "object",
  "required": ["template"],
  "additionalProperties": false,
  "properties": {
    "template": {
      "type": "object",
      "required": [
        "key",
        "family",
        "version",
        "difficulty_policy",
        "transcript",
        "ground_truth",
        "evaluation_items"
      ],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "pattern": "^[a-zA-Z_][\\w-]*$",
          "description": "Stable machine key for this template."
        },
        "family": {
          "type": "string",
          "pattern": "^[a-zA-Z_]\\w*$",
          "description": "Family this template belongs to (e.g., buried_constraint)."
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Semantic version of this template."
        },
        "difficulty_policy": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "distractor_turns": { "$ref": "#/$defs/difficultyIntMap" },
            "paraphrase_depth": { "$ref": "#/$defs/difficultyIntMap" },
            "override_timing": { "$ref": "#/$defs/difficultyStringMap" }
          }
        },
        "variables": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "generator"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "pattern": "^[a-zA-Z_]\\w*$" },
              "generator": { "type": "string", "minLength": 1 }
            }
          }
        },
        "transcript": {
          "type": "object",
          "required": ["turns"],
          "additionalProperties": false,
          "properties": {
            "turns": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["role"],
                "additionalProperties": false,
                "properties": {
                  "role": { "enum": ["user", "assistant", "system", "distractor_block"] },
                  "template": { "type": "string" },
                  "tags": { "type": "array", "items": { "type": "string" } },
                  "count": { "type": ["string", "integer"] }
                }
              }
            }
          }
        },
        "ground_truth": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "immutable_facts": { "type": "array", "items": { "type": "string" } },
            "locked_decisions": { "type": "array", "items": { "type": "string" } },
            "forbidden_behaviors": { "type": "array", "items": { "type": "string" } },
            "unresolved_items": { "type": "array", "items": { "type": "string" } },
            "deferred_items": { "type": "array", "items": { "type": "string" } },
            "entity_map": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        },
        "evaluation_items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["key", "type", "prompt", "expected"],
            "additionalProperties": false,
            "properties": {
              "key": { "type": "string", "pattern": "^[a-zA-Z_]\\w*$" },
              "type": { "type": "string", "minLength": 1 },
              "prompt": { "type": "string", "minLength": 1 },
              "expected": { "type": "object" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "difficultyIntMap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "easy": { "type": "integer", "minimum": 0 },
        "medium": { "type": "integer", "minimum": 0 },
        "hard": { "type": "integer", "minimum": 0 },
        "elite": { "type": "integer", "minimum": 0 }
      }
    },
    "difficultyStringMap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "easy": { "type": "string" },
        "medium": { "type": "string" },
        "hard": { "type": "string" },
        "elite": { "type": "string" }
      }
    }
  }
}
